# NordStern Anchor Template — environment (testnet).
# Real values are GENERATED by `node scripts/setup-testnet.mjs` into `.env`.
# This file documents the shape only. NEVER commit a real `.env`.

# ── Asset (USDC on Stellar testnet) ─────────────────────────────────────────────
# The anchor holds/transfers USDC; it does not issue it. Testnet issuer is Circle's;
# re-verify after each quarterly testnet reset.
ASSET_CODE=USDC
ASSET_ISSUER_PUBLIC=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# ── Network ─────────────────────────────────────────────────────────────────────
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Keys (GENERATED — do not fill by hand) ──────────────────────────────────────
# SEP-10 home-domain signing key (AP: SECRET_SEP10_SIGNING_SEED)
SIGNING_PUBLIC=
SIGNING_SECRET=
# Treasury = the USDC float account (AP asset `distribution_account`)
TREASURY_PUBLIC=
TREASURY_SECRET=

# ── Anchor Platform JWT secrets (GENERATED) ─────────────────────────────────────
SEP10_JWT_SECRET=
SEP24_INTERACTIVE_JWT_SECRET=
SEP24_MORE_INFO_JWT_SECRET=
SEP6_MORE_INFO_JWT_SECRET=

# ── Database ────────────────────────────────────────────────────────────────────
DB_USER=anchor
DB_PASSWORD=anchor

# ── Host port overrides (optional) ──────────────────────────────────────────────
# Defaults are canonical (5432 / 3000). Override to coexist with another stack.
# If you change BIZ_HOST_PORT for a real wallet flow, also update the SEP-24
# interactive_url base_url in config/anchor-platform.yaml.
# DB_HOST_PORT=5432
# BIZ_HOST_PORT=3000
# CLIENT_HOST_PORT=3001

# ── Adapter selection (mock-first; real vendors land in Phase D) ────────────────
KYC_PROVIDER=mock
FEE_PROVIDER=mock
DEPOSIT_PROVIDER=mock
PAYOUT_PROVIDER=mock
