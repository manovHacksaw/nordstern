# NordStern Anchor Template — environment (testnet).
# Real values are GENERATED by `node scripts/setup-testnet.mjs` into `.env`.
# This file documents the shape only. NEVER commit a real `.env`.

# ── Asset (USDC on Stellar testnet) ─────────────────────────────────────────────
# The anchor holds/transfers USDC; it does not issue it. Testnet issuer is Circle's;
# re-verify after each quarterly testnet reset.
ASSET_CODE=USDC
ASSET_ISSUER_PUBLIC=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# ── Network ─────────────────────────────────────────────────────────────────────
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Keys (GENERATED — do not fill by hand) ──────────────────────────────────────
# SEP-10 home-domain signing key (AP: SECRET_SEP10_SIGNING_SEED)
SIGNING_PUBLIC=
SIGNING_SECRET=
# Treasury = the USDC float account (AP asset `distribution_account`)
TREASURY_PUBLIC=
TREASURY_SECRET=

# ── Anchor Platform JWT secrets (GENERATED) ─────────────────────────────────────
SEP10_JWT_SECRET=
SEP24_INTERACTIVE_JWT_SECRET=
SEP24_MORE_INFO_JWT_SECRET=
SEP6_MORE_INFO_JWT_SECRET=

# ── Database ────────────────────────────────────────────────────────────────────
DB_USER=anchor
DB_PASSWORD=anchor

# ── Host port overrides (optional) ──────────────────────────────────────────────
# Defaults are canonical (5432 / 3000). Override to coexist with another stack.
# If you change BIZ_HOST_PORT for a real wallet flow, also update the SEP-24
# interactive_url base_url in config/anchor-platform.yaml.
# DB_HOST_PORT=5432
# BIZ_HOST_PORT=3000
# CLIENT_HOST_PORT=3001

# ── Adapter selection ───────────────────────────────────────────────────────────
# KYC defaults to REAL (didit) and fails closed — a money anchor never runs on mock
# identity checks by default. FX defaults to a live no-key feed (safe fallback).
KYC_PROVIDER=didit         # didit | surepass (real) — mock is dev-only, see below
# ALLOW_MOCK_KYC=true      # DEV ONLY: acknowledge that KYC_PROVIDER=mock auto-approves
                           # EVERY user. Ignored/forbidden on mainnet. Leave unset for real KYC.
FEE_PROVIDER=live          # cmc | live | mock  (selects the FX/rate source)
DEPOSIT_PROVIDER=mock      # mock | upi | razorpay  (razorpay = real verified INR collection)
PAYOUT_PROVIDER=mock       # mock  (Cashfree/RazorpayX: Phase D slice 2)

# Vendor config (used only when the matching provider is selected)
RATE_INR_USD=88.50
FX_URL=https://open.er-api.com/v6/latest/USD   # FEE_PROVIDER=live: generic USD→INR feed
# FEE_PROVIDER=cmc: CoinMarketCap USDC→INR (needs a paid tier for fiat convert)
# CMC_API_KEY=
# CMC_USDC_ID=3408          # Circle USD Coin
# CMC_TTL_MS=3600000        # rate cache window (1h) — long to conserve CMC credits
# SUREPASS_BASE_URL=https://sandbox.surepass.io
# SUREPASS_TOKEN=
# CASHFREE_APP_ID=
# CASHFREE_SECRET=
# CASHFREE_API_VERSION=2024-01-01
# CASHFREE_BASE_URL=https://sandbox.cashfree.com/payout
# ANCHOR_UPI_VPA=nordstern.anchor@upi
# ANCHOR_UPI_NAME="NordStern Anchor"
# DEPOSIT_PROVIDER=razorpay: real INR collection via Razorpay Checkout. KEY_ID is
# public; KEY_SECRET + WEBHOOK_SECRET are server-side only. rzp_test_* = sandbox,
# rzp_live_* = real money. Webhook → ${PUBLIC_BASE_URL}/webhooks/razorpay
# (events: payment.captured, order.paid). Requires PUBLIC_BASE_URL (ngrok in dev).
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_BUSINESS_NAME=NordStern
