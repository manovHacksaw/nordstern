# ─── Production .env template for the pilot ───────────────────────────────────────
# Copy to a git-ignored `.env` ON THE EC2 HOST and fill in. Pull secret values from AWS
# Secrets Manager (created by terraform): `aws secretsmanager get-secret-value --secret-id
# nordstern/pilot/platform` and `.../database`. NEVER commit the filled file.
#
# Bring up:  docker compose -f docker-compose.platform.yml -f docker-compose.prod.yml --env-file .env up -d

# ── AWS / region ──
AWS_REGION=ap-south-1

# ── RDS (from terraform output `rds_address` + the DB secret) ──
RDS_HOST=<nordstern-pilot-pg....rds.amazonaws.com>
DB_USER=nordstern_admin
DB_PASSWORD=<from Secrets Manager: nordstern/pilot/database>

# ── Platform crypto/secrets (from Secrets Manager: nordstern/pilot/platform) ──
MASTER_KEK=<32-byte base64 KEK — encrypts anchor signing keys>
CP_JWT_SECRET=<control-plane JWT secret>
PLATFORM_JWT_ACCESS_SECRET=<platform-api access JWT secret>
PLATFORM_JWT_REFRESH_SECRET=<platform-api refresh JWT secret>
SERVICE_SECRET=<backend→platform service secret (KYC propagation)>
CP_SERVICE_PASSWORD=<platform→control-plane service password>

# ── NordStern internal admin (admin.nordstern.live) — set STRONG values, not admin/admin ──
ADMIN_USERNAME=<strong admin username>
ADMIN_PASSWORD=<strong admin password (>=12 chars)>

# ── Per-anchor config dir on the host (created by setup) ──
ANCHOR_CONFIG_HOST_ROOT=/home/ec2-user/nordstern/anchor-configs

# ── Email (Resend) — verified sender domain ──
RESEND_API_KEY=<resend live key>
EMAIL_FROM=NordStern <noreply@nordstern.live>

# ── TLS (Let's Encrypt) ──
ACME_EMAIL=<ops email for cert notices>

# ── Universal DIDIT KYC (required — anchors fail closed without these) ──
DIDIT_API_KEY=<didit api key>
DIDIT_WORKFLOW_ID=<didit workflow id>
DIDIT_WEBHOOK_SECRET=<didit webhook secret>
