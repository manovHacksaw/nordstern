# ── Database (Supabase session pooler; append ?sslmode=no-verify) ─────────────
DATABASE_URL=postgresql://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=no-verify

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
ACCESS_TOKEN_TTL=900          # seconds (15m)
REFRESH_TOKEN_TTL=1209600     # seconds (14d)
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ── App / Email (Resend) ──────────────────────────────────────────────────────
APP_URL=http://localhost:3000
RESEND_API_KEY=              # empty = verification/reset links logged to console (dev)
EMAIL_FROM=NordStern <onboarding@resend.dev>

# ── Vault for tenant_secrets — 32-byte base64 (openssl rand -base64 32) ────────
SECRETS_KEK=
