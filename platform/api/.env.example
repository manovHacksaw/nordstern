# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://anchor:anchor@localhost:5432/nordstern_platform

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Auth (used from Phase 4) ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
ACCESS_TOKEN_TTL=900          # seconds (15m)
REFRESH_TOKEN_TTL=1209600     # seconds (14d)
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ── Email (used from Phase 4; Mailhog in dev) ─────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=NordStern <no-reply@nordstern.dev>
APP_URL=http://localhost:3000
