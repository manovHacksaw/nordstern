# Copy to terraform.tfvars and fill in. Only `resend_api_key` is required; the rest
# have pilot-appropriate defaults (see variables.tf).

aws_region  = "ap-northeast-1"
project     = "nordstern"
environment = "pilot"

# The one real external secret (no default).
resend_api_key = "re_xxxxxxxxxxxxxxxxxxxxxxxx"
email_from     = "NordStern <noreply@nordstern.live>"

# Compute — t3.large (8 GB) is the floor; t3.xlarge for several live anchors.
ec2_instance_type = "t3.large"

# Access the box via SSM Session Manager (default). To use SSH instead:
# enable_ssh        = true
# allowed_ssh_cidrs = ["203.0.113.4/32"]   # your IP only — never 0.0.0.0/0
# ec2_key_name      = "my-keypair"

# Database
db_instance_class        = "db.t3.small"
db_backup_retention_days = 7        # > 0 = automated backups + PITR
db_deletion_protection   = false    # true once you care about the data

# DNS — leave manage_dns = false unless your zone is in Route53.
domain_name = "nordstern.live"
manage_dns  = false
# When manage_dns = true and the zone already exists in Route53:
# route53_zone_id = "Z0123456789ABCDEFGHIJ"
